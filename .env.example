# Copy to .env:  cp .env.example .env
# Do not commit real secrets. Replace SECRET_KEY on every environment.

# ========= Required — every key must exist in .env =========

DJANGO_SECRET_KEY=
DJANGO_DEBUG=
DJANGO_ALLOWED_HOSTS=
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=

DJANGO_LANGUAGE_CODE=
DJANGO_TIME_ZONE=
DJANGO_USE_I18N=
DJANGO_USE_TZ=

DJANGO_EMAIL_BACKEND=

# Site + Brevo (transactional email API). Get API key from Brevo → SMTP & API.
DJANGO_SITE_NAME=
DJANGO_BREVO_API_KEY=
DJANGO_BREVO_SENDER_EMAIL=
DJANGO_BREVO_SENDER_NAME=
# Verification code validity and minimum seconds between resend emails.
DJANGO_EMAIL_VERIFICATION_EXPIRE_HOURS=
DJANGO_EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=
# Comma-separated domains (lowercase), e.g. gmail.com,yahoo.com,outlook.com
# Leave empty to allow any email domain.
DJANGO_SIGNUP_ALLOWED_EMAIL_DOMAINS=

DJANGO_DATABASE_ENGINE=
DJANGO_DATABASE_NAME=

DJANGO_STATIC_URL=
DJANGO_MEDIA_URL=
DJANGO_STATIC_ROOT=
DJANGO_MEDIA_ROOT=
DJANGO_STATICFILES_DIRS=

DJANGO_LOGIN_REDIRECT_URL=
DJANGO_LOGOUT_REDIRECT_URL=
DJANGO_LOGIN_URL=

DJANGO_SESSION_COOKIE_HTTPONLY=
DJANGO_CSRF_COOKIE_HTTPONLY=
DJANGO_SECURE_BROWSER_XSS_FILTER=
DJANGO_X_FRAME_OPTIONS=

DJANGO_SECURE_HSTS_SECONDS=
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=

# ---------- Example: PythonAnywhere (production-style) ----------
# Hostname: replace mustafajuba.pythonanywhere.com with yours (lowercase).
# SECRET_KEY: run on the server once:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# DJANGO_SECRET_KEY=<paste output here>
# DJANGO_DEBUG=false
# DJANGO_ALLOWED_HOSTS=mustafajuba.pythonanywhere.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://mustafajuba.pythonanywhere.com
# DJANGO_SECURE_SSL_REDIRECT=false
# DJANGO_LANGUAGE_CODE=ar
# DJANGO_TIME_ZONE=Africa/Cairo
# DJANGO_USE_I18N=true
# DJANGO_USE_TZ=true
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DJANGO_DATABASE_ENGINE=django.db.backends.sqlite3
# DJANGO_DATABASE_NAME=db.sqlite3
# DJANGO_STATIC_URL=/static/
# DJANGO_MEDIA_URL=/media/
# DJANGO_STATIC_ROOT=staticfiles
# DJANGO_MEDIA_ROOT=media
# DJANGO_STATICFILES_DIRS=static
# DJANGO_LOGIN_REDIRECT_URL=home
# DJANGO_LOGOUT_REDIRECT_URL=home
# DJANGO_LOGIN_URL=login
# DJANGO_SESSION_COOKIE_HTTPONLY=true
# DJANGO_CSRF_COOKIE_HTTPONLY=true
# DJANGO_SECURE_BROWSER_XSS_FILTER=true
# DJANGO_X_FRAME_OPTIONS=DENY
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true

# ---------- Example: local dev ----------
# DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
# DJANGO_SECURE_HSTS_SECONDS=0
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
